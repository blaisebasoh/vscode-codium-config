{
  // Input, Scrolling, Zooming Behavior
  "editor.mouseWheelScrollSensitivity": 4,
  "workbench.list.mouseWheelScrollSensitivity": 4,
  "terminal.integrated.mouseWheelScrollSensitivity": 4,

  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,

  "editor.cursorSmoothCaretAnimation": "explicit",

  // Formatting, Whitespace, Text Behavior
  "editor.insertSpaces": false,
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // Theme / Visual Settings
  "editor.fontFamily": "FiraCode Nerd Font Propo",
  // "editor.fontFamily": "JetBrainsMono Nerd Font",

  "workbench.colorCustomizations": {
    "editor.background": "#0c0c0c",
    "sideBar.background": "#0c0c0c",
    "titleBar.activeBackground": "#0c0c0c",
    "welcomePage.background": "#0c0c0c",
    "terminal.background": "#0c0c0c",
    "statusBar.background": "#0c0c0c",
    "editor.selectionBackground": "#5e5e5e30",
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.activityBar.location": "hidden",
  "workbench.tree.indent": 12,
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.editor.empty.hint": "hidden",
  "editor.dragAndDrop": false,
  "window.customTitleBarVisibility": "auto",

  // Explorer & File Management Behavior
  "explorer.compactFolders": true,
  "explorer.autoReveal": "focusNoScroll",
  "files.exclude": {
    "**/.manta_": true,
    "**/.vscode_": true,
    "**/output_/": true,
  },

  // Git / SCM Behavior
  "git.enabled": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "scm.alwaysShowActions": true,

  // Output & Panel Behavior
  "output.smartScroll.enabled": false,
  "debug.openExplorerOnEnd": true,

  // Terminal
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.hideOnStartup": "whenEmpty",

  // CMake
  "cmake.configureOnOpen": false,
  "cmake.useCMakePresets": "always",
  "cmake.options.statusBarVisibility": "visible",
  "cmake.showConfigureWithDebuggerNotification": false,
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask",
  ],

  // File Associations
  "files.associations": {
    "*.mx": "nx",
    "*.opp": "cpp",
    "*.hpp": "cpp",
    "*.shader": "cpp",
    "*.object": "cpp",
    "*.metal": "cpp",
  },

  // Language Overrides
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
  },
  "[c]": {
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true,
  },
  "[python]": {
    "editor.formatOnType": true,
  },

  // Editor Assistance / Intelligence
  "clangd.arguments": [
    "--header-insertion=never",
    "--function-arg-placeholders=0",
    "--compile-commands-dir=build",
  ],

  "editor.hover.enabled": "on",
  "editor.parameterHints.enabled": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true,
  },
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.links": false,
  "editor.codeLens": false,
  "editor.stickyScroll.enabled": false,

  // Workspace Trust & Security
  "security.workspace.trust.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",

  // Chat / AI Controls
  "chat.disableAIFeatures": true,

  // Extensions & Feature Toggles
  "extensions.ignoreRecommendations": true,
  "better-comments.multilineComments": true,
  "dotnetAcquisitionExtension.suppressOutput": true,

  // Sync Ignored Settings
  "settingsSync.ignoredSettings": [
    "editor.mouseWheelScrollSensitivity",
    "workbench.list.mouseWheelScrollSensitivity",
    "terminal.integrated.mouseWheelScrollSensitivity",
    "C_Cpp.intelliSenseEngine",
  ],

  // vim settings
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"],
    },
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"],
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"],
    },
    {
      "before": ["K"],
      "commands": ["lineBreakInsert"],
      "silent": true,
    },
  ],
  "vim.normalModeKeyBindings": [
    {
      "before": ["<C-n>"],
      "commands": [":nohl"],
    },
    {
      "before": ["leader", "w"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": [":"],
      "commands": ["workbench.action.showCommands"],
      "silent": true,
    },
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
  },
  // To improve performance
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
  },

  //
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "window.restoreWindows": "none",
  "workbench.layoutControl.enabled": false,
  "workbench.editor.titleScrollbarVisibility": "hidden",
  "window.title": "${activeEditorShort}",
  "window.titleSeparator": " . ",
  "zenMode.showTabs": "single",
  "window.density.editorTabHeight": "compact",
  "debug.hideLauncherWhileDebugging": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "explorer.confirmDelete": false,
  "godot.csharp.executablePath": "D:\\Applications\\Godot_v4.6.1-stable_mono_win64",
  "extensions.autoUpdate": false,
  "editor.minimap.enabled": false,
  "terminal.integrated.stickyScroll.enabled": false,
  "terminal.integrated.initialHint": false,
  "cmake.configureOnEdit": false,
  "workbench.navigationControl.enabled": false,
  "clangd.fallbackFlags": [
    "-ID:/Library/vcpkg/installed/x64-mingw-dynamic/include",
  ],
  "[markdown]": {
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": false,
    },
  },
  "search.quickOpen.includeHistory": false,
  "editor.formatOnSave": true,
  "svelte.enable-ts-plugin": true,
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "window.zoomLevel": -0.5,
  "markdown.preview.fontFamily": "'JetBrainsMono NF'",
  "markdown.preview.typographer": true,
  "markdown.preview.fontSize": 12,
  "simpleCodingTimeTracker.statusBar.backgroundStyle": "default",
  "simpleCodingTimeTracker.enableDevCommands": false,
  "window.commandCenter": false,
  "window.menuBarVisibility": "compact",
  "workbench.editor.showTabs": "none",
  "workbench.tips.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.sideBar.location": "right",
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "material-icon-theme.hidesExplorerArrows": true,
  "explorer.confirmDragAndDrop": false,
  "editor.cursorBlinking": "solid",
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.5,
  "editor.matchBrackets": "never",
  "files.insertFinalNewline": true,
  "scm.diffDecorations": "none",
  "editor.lineNumbers": "relative",
  "editor.detectIndentation": false,
  "editor.showFoldingControls": "never",
  "editor.guides.indentation": false,
  "editor.foldingHighlight": false,
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor",
  },
}
